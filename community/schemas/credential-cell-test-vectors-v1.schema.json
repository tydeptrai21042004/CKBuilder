{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ckb-degree/schemas/credential-cell-test-vectors-v1.schema.json",
  "title": "CKB Degree credential Cell test vectors v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "protocol", "generatedBy", "recordLength", "credentialId", "credentialHash", "issuerLockHash", "vectors"],
  "properties": {
    "schema": { "const": "ckb-degree-cell-test-vectors/v1" },
    "protocol": { "const": "ckb-degree-credential-cell/v1" },
    "generatedBy": { "type": "string" },
    "recordLength": { "const": 75 },
    "credentialId": { "type": "string", "minLength": 1 },
    "credentialHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "issuerLockHash": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "vectors": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "valid", "cellData", "expected"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "valid": { "type": "boolean" },
          "cellData": { "type": "string", "pattern": "^0x(?:[0-9a-f]{2})+$" },
          "expected": { "type": "object" }
        }
      }
    }
  }
}
